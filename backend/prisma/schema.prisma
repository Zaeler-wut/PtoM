generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

model User {
  id String @id @default(uuid())

  firstName String
  lastName String

  email String @unique
  phone String?
  lineId String?

  citizenId String?
  address String?

  password String

  role Role @default(USER)

  isActive Boolean @default(true)
  lastLogin DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicles Vehicle[]
  bookings Booking[]
  payments Payment[]
  contracts Contract[]
  bills Bill[]
  moveOutBills MoveOutBill[]

  managedProperties PropertyAdmin[]
  refreshTokens RefreshToken[]
  adminLimit AdminLimit?
}

model AdminLimit {
  id            String  @id @default(uuid())
  userId        String  @unique
  propertyLimit Int     @default(3)
  user          User    @relation(fields: [userId], references: [id])
}

model Vehicle {
  id String @id @default(uuid())

  userId String
  plateNumber String
  type String

  user User @relation(fields: [userId], references: [id])
}

model Property {
  id String @id @default(uuid())

  name String
  address String
  googleMap String?

  description String?

  priceMin Int
  priceMax Int

  contractTerm String?

  bankName String
  bankAccount String
  bankHolder String

  paymentQrUrl String?
  logoUrl String?
  preparingDays Int @default(3)

  lat           Float?
  lng           Float?

  billNote      String?
  phone         String?

  createdAt DateTime @default(now())

  roomTypes RoomType[]
  rooms Room[]
  bookings Booking[]

  facilities PropertyFacility[]
  images PropertyImage[]

  admins PropertyAdmin[]
}

model PropertyImage {
  id String @id @default(uuid())

  propertyId String
  url String
  isCover Boolean @default(false)

  property Property @relation(fields: [propertyId], references: [id])
}

model PropertyAdmin {
  id String @id @default(uuid())

  propertyId String
  userId String

  property Property @relation(fields: [propertyId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([propertyId, userId])
}

model RoomType {
  id String @id @default(uuid())

  propertyId String

  name String
  description String?

  size Float?
  maxOccupants Int

  roomPrice Int
  furniturePrice Int?

  bookingFee Int
  advanceRent Int

  securityDeposit Int

  waterRate Float
  electricRate Float

  allowOnlineBooking Boolean @default(true)

  property Property @relation(fields: [propertyId], references: [id])

  rooms Room[]
  images RoomTypeImage[]
  facilities RoomFacility[]
  bookings Booking[]

  fees RoomTypeFee[]
}

model RoomTypeFee {
  id String @id @default(uuid())

  roomTypeId String

  title String
  amount Int

  roomType RoomType @relation(fields: [roomTypeId], references: [id])
}

model RoomTypeImage {
  id String @id @default(uuid())

  roomTypeId String
  url String

  roomType RoomType @relation(fields: [roomTypeId], references: [id])
}

model Room {
  id String @id @default(uuid())

  propertyId String
  roomTypeId String

  roomNumber String
  floor Int?

  status RoomStatus

  property Property @relation(fields: [propertyId], references: [id])
  roomType RoomType @relation(fields: [roomTypeId], references: [id])

  contracts Contract[]
  bookings Booking[]
  bills Bill[]
  meters MeterReading[]
  moveOutBills MoveOutBill[]

  @@unique([propertyId, roomNumber])
}

enum RoomStatus {
  AVAILABLE
  RESERVED
  OCCUPIED
  PREPARING
  MAINTENANCE
}

model Facility {
  id String @id @default(uuid())

  name String @unique

  propertyFacilities PropertyFacility[]
  roomFacilities RoomFacility[]
}

model PropertyFacility {
  id String @id @default(uuid())

  propertyId String
  facilityId String

  property Property @relation(fields: [propertyId], references: [id])
  facility Facility @relation(fields: [facilityId], references: [id])

  @@unique([propertyId, facilityId])
}

model RoomFacility {
  id String @id @default(uuid())

  roomTypeId String
  facilityId String

  roomType RoomType @relation(fields: [roomTypeId], references: [id])
  facility Facility @relation(fields: [facilityId], references: [id])

  @@unique([roomTypeId, facilityId])
}

model Booking {
  id String @id @default(uuid())

  propertyId String
  roomTypeId String
  roomId String?

  userId String

  moveInDate DateTime

  bookingFee Int
  slipUrl String

  status BookingStatus

  createdAt DateTime @default(now())
  assignedAt DateTime?

  property Property @relation(fields: [propertyId], references: [id])
  roomType RoomType @relation(fields: [roomTypeId], references: [id])
  room Room? @relation(fields: [roomId], references: [id])
  user User @relation(fields: [userId], references: [id])

  contract Contract?
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CANCELLED
}

model Contract {
  id String @id @default(uuid())

  userId String
  roomId String
  bookingId String? @unique

  startDate DateTime
  endDate DateTime

  securityDeposit Int

  contractType ContractType
  status ContractStatus

  pdfUrl String?
  moveOutNoticeDate DateTime?

  updatedAt         DateTime  @updatedAt
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  room Room @relation(fields: [roomId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])

  bills Bill[]
  moveOutBills MoveOutBill[]
}

enum ContractStatus {
  ACTIVE
  MOVE_OUT_NOTICE
  ENDED
}

enum ContractType {
  ONLINE
  OFFLINE
}

model MeterReading {
  id String @id @default(uuid())

  roomId String

  month Int
  year Int

  waterMeter Float
  electricMeter Float

  createdAt DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id])

  images MeterImage[]

  @@unique([roomId, month, year])
}

model MeterImage {
  id String @id @default(uuid())

  meterReadingId String

  url String
  type MeterType

  meterReading MeterReading @relation(fields: [meterReadingId], references: [id])
}

enum MeterType {
  WATER
  ELECTRIC
}

model Bill {
  id String @id @default(uuid())

  contractId String
  roomId String
  userId String

  month Int?
  year Int?

  roomRent Int
  furnitureRent Int?

  total Int

  status BillStatus

  pdfUrl String?

  createdAt DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id])
  room Room @relation(fields: [roomId], references: [id])
  user User @relation(fields: [userId], references: [id])

  items BillItem[]
  payments Payment[]
}

model BillItem {
  id String @id @default(uuid())

  billId String

  title String
  amount Int

  bill Bill @relation(fields: [billId], references: [id])
}

enum BillStatus {
  DRAFT
  READY
  PENDING
  VERIFYING
  PAID
}

model Payment {
  id String @id @default(uuid())

  userId String
  billId String

  amount Int

  slipUrl String?

  status PaymentStatus
  verifiedAt DateTime?
  verifiedBy String?

  updatedAt  DateTime  @updatedAt
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  bill Bill @relation(fields: [billId], references: [id])
}

enum PaymentStatus {
  PENDING
  VERIFYING
  CONFIRMED
  REJECTED
}

model MoveOutBill {
  id String @id @default(uuid())

  contractId String
  roomId String
  userId String

  moveOutDate DateTime

  waterStart Float
  waterEnd Float

  electricStart Float
  electricEnd Float

  totalCharge Int
  refundAmount Int
  billingStartDay Int?
  billingEndDay   Int?
  status MoveOutBillStatus

  createdAt DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id])
  room Room @relation(fields: [roomId], references: [id])
  user User @relation(fields: [userId], references: [id])

  items MoveOutBillItem[]
}

model MoveOutBillItem {
  id String @id @default(uuid())

  moveOutBillId String

  title String
  amount Int

  moveOutBill MoveOutBill @relation(fields: [moveOutBillId], references: [id])
}

enum MoveOutBillStatus {
  DRAFT
  CONFIRMED
  COMPLETED
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}